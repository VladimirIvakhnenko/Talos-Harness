# PostgreSQL
POSTGRES_USER=plc
POSTGRES_PASSWORD=plc_secret
POSTGRES_DB=plc_agent
DATABASE_URL=postgresql+asyncpg://plc:plc_secret@localhost:5432/plc_agent

# OpenRouter (когда LLM_BACKEND=openrouter)
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# LLM: openrouter | lmstudio (LM Studio на хосте, OpenAI-compatible API)
LLM_BACKEND=openrouter
LMSTUDIO_BASE_URL=http://localhost:1234/v1
# Docker + LM Studio на Windows: http://host.docker.internal:1234/v1
LMSTUDIO_API_KEY=lm-studio

# Models (при lmstudio — id модели из GET /v1/models в LM Studio)
PLANNER_MODEL=qwen/qwen3.6-27b
ENGINEER_MODEL=qwen/qwen3.6-27b
RETRIEVER_MODEL=qwen/qwen3.6-27b
# Для локальных моделей сузьте контекст, напр. AGENT_CONTEXT_LIMIT=32768 AGENT_MAX_TOKENS=8192

# Embeddings: local = llama.cpp GGUF server | openrouter = API
EMBEDDING_BACKEND=local
EMBEDDING_MODEL=embeddinggemma-300m
EMBEDDING_DIMENSIONS=768
EMBEDDING_MAX_CHARS=1500
# Docker: http://llama-embedding:8080 | локально: http://localhost:8080
# При Tailscale: если контейнеры не видят openrouter.ai — в docker-compose для api/ui уже добавлены 8.8.8.8 и 1.1.1.1
EMBEDDING_GGUF_FILE=embeddinggemma-300M-Q8_0.gguf
LLAMA_EMBEDDING_URL=http://localhost:8080

# MatIEC
MATIEC_URL=http://localhost:8001

# Agent
AGENT_MAX_ITERATIONS=10
EXPERT_MAX_ITERATIONS=5
EXPERT_MAX_VALIDATION_ATTEMPTS=3

# ST coding benchmark
BENCHMARK_MAX_VALIDATION_ATTEMPTS=2
BENCHMARK_ST_GUIDE_PATH=benchmark/assets/IEC-61131-3-ST-GUIDE.md

# context_limit = prompt + completion; max_tokens — только на ответ
AGENT_CONTEXT_LIMIT=131072
AGENT_INPUT_RESERVE=16384
AGENT_MAX_TOKENS=120000
AGENT_TEMPERATURE=0.1
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K_RETRIEVAL=5

# OCR (paddle | openrouter)
OCR_BACKEND=openrouter
OCR_MODEL=qwen/qwen3-vl-8b-thinking
# PaddleOCR (when OCR_BACKEND=paddle)
OCR_LANG=ru
OCR_VERSION=PP-OCRv5
OCR_USE_SERVER_MODELS=true
OCR_MIN_SCORE=0.5

# App
APP_ENV=development
LOG_LEVEL=INFO
UPLOAD_DIR=./uploads

# Gradio UI
GRADIO_SERVER_PORT=7860
API_BASE_URL=http://localhost:8000
